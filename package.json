"use client"

import { useEffect, useState } from "react"
import { motion } from "framer-motion"

export default function JustPage() {
  const [mounted, setMounted] = useState(false)
  useEffect(() => { setMounted(true) }, [])

  if (!mounted) return <div style={{ background: "#000", minHeight: "100vh" }} />

  return (
    <div style={{ background: "#000", color: "#fff", minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center" }}>
      <motion.h1
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        style={{ fontFamily: "sans-serif" }}
      >
        OK — framer-motion fonctionne
      </motion.h1>
    </div>
  )
}